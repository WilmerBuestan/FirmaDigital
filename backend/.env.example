# ── Base de datos ────────────────────────────────────────────────────────────
# URL de conexión a PostgreSQL en Supabase.
# Cópiala desde: Supabase → proyecto → Settings → Database → Connection string → URI
# Cambia [YOUR-PASSWORD] por la contraseña del proyecto.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── Seguridad JWT ─────────────────────────────────────────────────────────────
# Genera una clave fuerte con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-hex-de-64-caracteres

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL pública del frontend en Vercel (el QR de los PDFs apunta aquí).
FRONTEND_URL=https://tu-proyecto.vercel.app
